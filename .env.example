# Bridge Radar — environment configuration
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ─── Database ─────────────────────────────────────────────────────────────────
# v0 default: local SQLite, no setup required
DATABASE_URL=sqlite://./data/radar.db

# Production: Postgres + Timescale (see docker-compose.yml)
# DATABASE_URL=postgres://radar:radar@localhost:5432/radar

# ─── Redis (production cache; v0 runs without) ────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Solana ───────────────────────────────────────────────────────────────────
# Default: public mainnet RPC (rate-limited, fine for dev).
# Production: Helius (https://helius.dev) for low-latency Geyser + websocket.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
# HELIUS_API_KEY=

# ─── EVM RPCs ─────────────────────────────────────────────────────────────────
# Defaults are public endpoints; swap for Alchemy/QuickNode in prod.
ETH_RPC_URL=https://eth.llamarpc.com
ETH_WS_URL=wss://ethereum-rpc.publicnode.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BNB_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com

# ─── API server ───────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3000

# ─── Dashboard ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/v1/ws

# ─── Attester (on-chain oracle pusher) ────────────────────────────────────────
# Path to a Solana keypair JSON. Generate with: solana-keygen new --outfile attester.json
# NEVER commit the keypair file — it is gitignored.
ATTESTER_KEYPAIR_PATH=./attester.json
ORACLE_PROGRAM_ID=
ATTESTER_PUSH_INTERVAL_SECS=60

# ─── Alerter sinks (optional — alerter dry-runs if all are unset) ─────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
# ALERT_WEBHOOK_URL=

# ─── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=radar=info,sqlx=warn
